{
  "version": 2,
  "rewrites": [
    { 
      "source": "/api", 
      "destination": "/api/index.js" 
    },
    { 
      "source": "/(.*)", 
      "destination": "/public/$1" 
    }
  ],
  "headers": [
    {
      "source": "/api",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET" }
      ]
    }
  ]
}
